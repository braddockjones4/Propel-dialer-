# ─────────────────────────────────────────────────────────────────────────────
# Propel Dialer — Backend Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Render, Railway, Supabase, or local)
DATABASE_URL=postgresql://user:password@localhost:5432/propel_dialer

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
# Allowed CORS origin — set to your frontend URL in production
FRONTEND_URL=http://localhost:5173

# ── Auth ─────────────────────────────────────────────────────────────────────
# Long random string — generate with: openssl rand -base64 48
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# ── Agent name & phone (used in AI scripts, SMS templates, voicemail messages)
AGENT_NAME=Your Name Here
AGENT_PHONE=+1XXXXXXXXXX

# ── Twilio Core (console.twilio.com → Account Info) ──────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio API Key (console.twilio.com → API keys & tokens → Create API key)
# Used for browser-based calling (Twilio Client JS)
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_api_secret_here

# Twilio TwiML App SID (console.twilio.com → Voice → TwiML Apps → Create)
# Voice Request URL must point to: https://your-backend.com/api/dialer/voice
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Caller ID — a Twilio phone number you own (format: +1XXXXXXXXXX)
TWILIO_CALLER_ID=+1XXXXXXXXXX

# ── Public backend URL ────────────────────────────────────────────────────────
# Used for Twilio webhooks. In dev: your ngrok URL. In prod: your Render/Railway URL.
# Example: https://propel-dialer-backend.onrender.com
NGROK_URL=https://your-backend-url.com

# ── OpenAI (platform.openai.com/api-keys) ────────────────────────────────────
# Required for: call transcription (Whisper), call scoring (GPT-4o-mini), AI scripts, AI Agent
OPENAI_API_KEY=sk-...

# ── Anthropic (console.anthropic.com) ────────────────────────────────────────
# Required for: AI Agent autonomous follow-ups
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the default model (defaults to claude-haiku-4-5-20251001 for cost efficiency)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Google OAuth (console.cloud.google.com → APIs & Services → Credentials) ──
# Required for: Gmail email blast, Google Contacts import
# Authorized redirect URI: https://your-backend.com/api/contacts/google/callback
#                     and: https://your-backend.com/api/gmail/oauth/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── SendGrid (app.sendgrid.com → Settings → API Keys) ────────────────────────
# Required for: password reset emails
SENDGRID_API_KEY=SG.xxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ── Voicemail script (optional — used as default TTS voicemail in dialer) ────
VOICEMAIL_SCRIPT=Hi, this is AGENT_NAME calling about your property. Please give me a call back at your earliest convenience. Thank you!

# ── Encryption key (optional — used for storing OAuth tokens at rest) ─────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-hex-key-here

# ── Stripe (stripe.com/docs/keys) — billing, currently unused ────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ELITE=price_...

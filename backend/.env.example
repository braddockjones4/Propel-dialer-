# ─────────────────────────────────────────────
# Propel Dialer — Backend Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Twilio Core (from console.twilio.com → Account Info)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio API Key (console.twilio.com → API keys & tokens → Create API key)
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_api_secret_here

# Twilio TwiML App SID (console.twilio.com → Voice → TwiML Apps → Create)
# Voice Request URL should point to: https://your-backend.com/voice
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Caller ID — a Twilio phone number you own (console.twilio.com → Phone Numbers)
# Format: +1XXXXXXXXXX
TWILIO_CALLER_ID=+1XXXXXXXXXX

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

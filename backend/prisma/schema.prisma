generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id          String    @id @default(cuid())
  firstName   String
  lastName    String
  phone       String?   @unique
  address     String?
  city        String?
  state       String?
  zip         String?
  email       String?
  source      String    @default("manual") // expired, fsbo, circle, past-client, manual
  status      String    @default("new")    // new, contacted, callback, hot, appointment, closed, dnc
  notes          String?
  contactGroup   String?   // user-defined group name e.g. "AYC Group"
  leadScore   Int?      // 0-100 AI-computed priority score
  timezone    String?   // e.g. "America/New_York" derived from area code
  lastReplyAt DateTime? // last inbound SMS — boosts lead score
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  calls        Call[]
  messages     Message[]
  appointments Appointment[]
  agentActions AgentAction[]
  agentPaused  Boolean       @default(false) // exclude this contact from autonomous agent
}

model Call {
  id           String   @id @default(cuid())
  contactId    String
  contact      Contact  @relation(fields: [contactId], references: [id])
  duration     Int      @default(0)
  disposition  String?
  notes        String?
  recordingUrl String?
  twilioSid    String?
  transcript   String?  // AI Whisper transcription
  aiScore      Int?     // 0-100 call quality score
  aiNotes      String?  // AI coaching notes
  calledAt     DateTime @default(now())
}

model Message {
  id          String   @id @default(cuid())
  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id])
  direction   String   // inbound | outbound
  body        String
  fromNumber  String
  toNumber    String
  twilioSid   String?
  status      String   @default("sent")
  sentAt      DateTime @default(now())
}

model VoicemailScript {
  id        String   @id @default(cuid())
  body      String
  updatedAt DateTime @updatedAt
}

model LocalNumber {
  id          String   @id @default(cuid())
  number      String   @unique  // E.164 format: +14105551234
  areaCode    String            // "410"
  state       String?           // "MD"
  label       String?           // optional friendly label
  active      Boolean  @default(true)
  purchasedAt DateTime @default(now())
}

model ScheduledBlast {
  id          String   @id @default(cuid())
  message     String
  filter      String            // JSON: { source?, status? }
  scheduledAt DateTime
  status      String   @default("pending")  // pending | sent | cancelled
  sentCount   Int?
  failCount   Int?
  createdAt   DateTime @default(now())
}

model Appointment {
  id          String   @id @default(cuid())
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id])
  title       String   @default("Listing Appointment")
  scheduledAt DateTime
  duration    Int      @default(60)   // minutes
  location    String?
  notes       String?
  status      String   @default("confirmed") // confirmed | cancelled | completed
  smsSent     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  body      String   // HTML body
  trigger   String?  // hot-lead | callback | no-answer | manual
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailLog {
  id          String   @id @default(cuid())
  contactId   String?
  toEmail     String
  subject     String
  body        String
  status      String   @default("sent")  // sent | failed | opened
  openedAt    DateTime?
  twilioSid   String?  // SendGrid message ID
  createdAt   DateTime @default(now())
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  name           String   @default("")
  role           String   @default("agent")   // agent | admin
  plan           String   @default("trial")   // trial | starter | pro | elite
  stripeCustomerId   String?
  stripeSubId        String?
  planExpiresAt  DateTime?
  gmailAccessToken  String?   // OAuth access token for Gmail API
  gmailRefreshToken String?   // OAuth refresh token (long-lived)
  gmailEmail        String?   // Connected Gmail address
  gmailTokenExpiry  DateTime? // When access token expires
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  dialerSettings DialerSettings?
}


// ─── Sequential Dialer Settings ──────────────────────────────────────────────
model DialerSettings {
  id            String   @id @default(cuid())
  userId        String?  @unique            // null = legacy singleton row
  user          User?    @relation(fields: [userId], references: [id])
  callMode      String   @default("webrtc") // webrtc | bridge
  personalPhone String   @default("")
  phoneVerified Boolean  @default(false)    // personalPhone is a Twilio Verified Caller ID
  voicemailUrl  String?                     // public URL Twilio uses to <Play> the voicemail
  voicemailSid  String?                     // Twilio RecordingSid (legacy phone-recorded VMs)
  voicemailData String?                     // base64 data URL of browser-recorded voicemail audio
  icloudEmail   String?                     // Apple ID email for CardDAV sync
  icloudAppPwd  String?                     // App-Specific Password (AES-256 encrypted)
  updatedAt     DateTime @updatedAt
}

// ─── Contact Groups ───────────────────────────────────────────────────────────
// Named user-defined groups (e.g. "AYC Group"). The actual assignment lives in
// Contact.contactGroup (a plain string) to keep queries simple; this table
// persists the list of groups so empty groups survive reloads and the AI agent
// can discover / create them server-side.
model ContactGroup {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#9ca3af")
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Autonomous AI Agent ──────────────────────────────────────────────────────
// Singleton config row (id = "singleton") controlling the autonomous agent.
model AgentSettings {
  id                 String   @id @default("singleton")
  enabled            Boolean  @default(true)
  // off = disabled, review = draft & queue for approval, auto = send within guardrails
  autonomyMode       String   @default("review") // off | review | auto
  model              String   @default("claude-haiku-4-5-20251001")
  agentName          String   @default("Propel Assistant")
  persona            String   @default("A warm, concise, professional real estate assistant who books appointments and keeps leads engaged. Never pushy, never spammy.")
  tone               String   @default("friendly-professional")
  goals              String   @default("Respond fast, qualify the lead, and book a listing appointment. Answer questions helpfully. Hand off to the human agent when unsure.")
  autoBookAppointments Boolean @default(true)
  // Guardrails
  quietHoursStart    Int      @default(21)   // 24h local hour when outbound SMS stops
  quietHoursEnd      Int      @default(8)    // 24h local hour when outbound SMS may resume
  dailySmsCapPerContact Int   @default(4)
  maxAgentRepliesPerThread Int @default(6)   // before forcing human handoff
  escalateKeywords   String   @default("lawyer,attorney,sue,complaint,harass,report you,scam,cease")
  updatedAt          DateTime @updatedAt
}

// Every action the agent proposes or takes — the approval queue AND the activity log.
model AgentAction {
  id           String    @id @default(cuid())
  contactId    String?
  contact      Contact?  @relation(fields: [contactId], references: [id])
  type         String    // sms | followup | appointment | status | note | dnc | escalate
  status       String    @default("pending") // pending | approved | sent | executed | scheduled | rejected | failed | skipped
  channel      String    @default("sms")     // sms | email | system
  payload      String    @default("{}")      // JSON: { message?, title?, scheduledAt?, status?, note?, ... }
  reasoning    String?                       // why the agent chose this
  source       String    @default("inbox-agent") // inbox-agent | followup-agent | manual
  scheduledFor DateTime?                     // for scheduled/deferred actions
  error        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  executedAt   DateTime?

  @@index([status])
  @@index([contactId])
  @@index([scheduledFor])
}
